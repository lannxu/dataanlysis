# Replace talent.example.com with the real domain.
# The app is expected to listen on 127.0.0.1:3000.
map $http_upgrade $connection_upgrade {
    default upgrade;
    ''      close;
}

upstream talent_review_app {
    server 127.0.0.1:3000;
    keepalive 32;
}

server {
    listen 80;
    listen [::]:80;
    server_name talent.example.com;

    # Excel files with embedded photos can be relatively large.
    client_max_body_size 35m;

    location / {
        proxy_pass http://talent_review_app;
        proxy_http_version 1.1;

        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Host $host;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Forwarded-Port $server_port;

        # Required for real-time employee switching and mobile sync.
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection $connection_upgrade;
        proxy_read_timeout 3600s;
        proxy_send_timeout 3600s;

        proxy_buffering off;
    }
}